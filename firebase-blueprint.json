{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation date" }
      },
      "required": ["uid", "email"]
    },
    "NewsCheck": {
      "title": "NewsCheck",
      "description": "A record of a news article analysis",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user who performed the check" },
        "text": { "type": "string", "description": "The news headline or article text analyzed" },
        "label": { "type": "string", "enum": ["Real", "Fake"], "description": "The prediction result" },
        "confidence": { "type": "number", "description": "Confidence percentage (0-100)" },
        "explanation": { "type": "string", "description": "AI's reasoning for the prediction" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the check was performed" }
      },
      "required": ["userId", "text", "label", "confidence", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/news_checks/{checkId}": {
      "schema": "NewsCheck",
      "description": "History of news analysis checks"
    }
  }
}
