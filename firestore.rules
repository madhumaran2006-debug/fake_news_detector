rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, email format)
    //   - displayName: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: news_checks
    // Document ID: checkId (auto-generated)
    // Fields:
    //   - userId: string (required)
    //   - text: string (required, max 10000 chars)
    //   - label: string (required, 'Real' or 'Fake')
    //   - confidence: number (required, 0-100)
    //   - explanation: string (optional)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.email.size() > 0;
    }

    function isValidNewsCheck(data) {
      return data.keys().hasAll(['userId', 'text', 'label', 'confidence', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.text is string && data.text.size() > 0 && data.text.size() < 10000 &&
             data.label in ['Real', 'Fake'] &&
             data.confidence is number && data.confidence >= 0 && data.confidence <= 100;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /news_checks/{checkId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidNewsCheck(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
